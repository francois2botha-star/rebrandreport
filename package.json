{
  "name": "rebrandreport",
  "private": true,
  "version": "1.0",
  "description": "RolloutHQ Enterprise Rollout Management Platform with Supabase-backed workflows.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/francois2botha-star/rebrandreport.git"
  },
  "homepage": "https://github.com/francois2botha-star/rebrandreport",
  "bugs": {
    "url": "https://github.com/francois2botha-star/rebrandreport/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prepare-pages.mjs",
    "preview": "vite preview",
    "website:preview": "npx serve website -l 4180",
    "check": "tsc -b --pretty false",
    "seed:auth": "node scripts/seed-auth.mjs",
    "seed:profiles": "node scripts/seed-profiles.mjs",
    "seed:sample-projects": "node scripts/seed-sample-projects.mjs",
    "apply:profiles": "node scripts/apply-profiles-schema.mjs",
    "apply:rls": "node scripts/apply-rls-hardening.mjs",
    "check:rls": "node scripts/check-rls-scope.mjs",
    "check:voice-storage": "node scripts/check-voice-storage.mjs",
    "reset:passwords": "node scripts/reset-auth-passwords.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.90.0",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.542.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.62.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.8.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
